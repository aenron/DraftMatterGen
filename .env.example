APP_NAME=draft-reason-service
APP_ENV=production
LOG_LEVEL=INFO
LOG_JSON=false
TZ=Asia/Shanghai

API_KEY_ENABLED=false
SERVICE_API_KEY=replace-me

LLM_BASE_URL=https://llm.example.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=your-model-name
LLM_CHAT_COMPLETIONS_PATH=/chat/completions
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=300
LLM_RESPONSE_FORMAT_JSON=true

UPLOAD_MAX_MB=20
EXTRACT_MAX_CHARS=50000
MAX_DOCUMENT_CHUNKS=8
ALLOWED_EXTENSIONS=docx,doc,txt
TEMP_DIR=/tmp/draft-reason
LIBREOFFICE_BINARY=libreoffice
CONVERSION_TIMEOUT_SECONDS=60
