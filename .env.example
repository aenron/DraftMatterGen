# 应用名称，用于日志和 OpenAPI 文档标题
APP_NAME=draft-reason-service
# 运行环境标识，例如 production、staging、test
APP_ENV=production
# 日志级别，可选 DEBUG、INFO、WARNING、ERROR
LOG_LEVEL=INFO
# 是否输出 JSON 格式日志，生产日志平台采集时可设为 true
LOG_JSON=false
# 容器或进程时区
TZ=Asia/Shanghai

# 是否启用 API Key 鉴权
API_KEY_ENABLED=false
# 启用鉴权时客户端需通过 X-API-Key 传入的密钥
SERVICE_API_KEY=replace-me

# OpenAI 兼容模型服务基础地址
LLM_BASE_URL=https://llm.example.com/v1
# 模型服务 API Key；如果后端不需要鉴权可留空
LLM_API_KEY=replace-me
# 模型名称
LLM_MODEL=your-model-name
# Chat Completions 接口路径
LLM_CHAT_COMPLETIONS_PATH=/chat/completions
# 单次模型请求超时时间，单位秒
LLM_TIMEOUT_SECONDS=60
# 模型调用失败或响应格式异常时的最大重试次数
LLM_MAX_RETRIES=2
# 全局模型调用并发上限，拟稿事由和文档摘要共用
LLM_MAX_CONCURRENCY=2
# 模型采样温度，越低输出越稳定
LLM_TEMPERATURE=0.1
# 拟稿事由模型输出 token 上限；摘要接口会使用不低于 800 的上限
LLM_MAX_TOKENS=300
# 是否向模型请求 JSON 对象响应；模型不兼容 response_format 时设为 false
LLM_RESPONSE_FORMAT_JSON=true
# 备用 OpenAI 兼容模型服务基础地址；地址和模型均配置后启用
BACKUP_LLM_BASE_URL=
# 备用模型服务 API Key；如果后端不需要鉴权可留空
BACKUP_LLM_API_KEY=
# 备用模型名称；与 BACKUP_LLM_BASE_URL 同时配置后启用
BACKUP_LLM_MODEL=
# 备用模型 Chat Completions 接口路径
BACKUP_LLM_CHAT_COMPLETIONS_PATH=/chat/completions

# 单个上传文件大小上限，单位 MB
UPLOAD_MAX_MB=20
# 拟稿事由接口单次直接处理的最大字符数，超过后按切片合并
EXTRACT_MAX_CHARS=50000
# 拟稿事由接口允许的最大文档切片数
MAX_DOCUMENT_CHUNKS=8
# 拟稿事由接口允许的文件扩展名
ALLOWED_EXTENSIONS=docx,doc,txt
# 文档摘要接口允许的文件扩展名；xlsx 允许时会返回 ignored，不进入模型摘要
SUMMARY_ALLOWED_EXTENSIONS=docx,doc,pdf,txt,xlsx
# 临时文件目录，同步解析完成后会清理
TEMP_DIR=/tmp/draft-reason
# LibreOffice 可执行文件路径，用于旧版 doc 转换
LIBREOFFICE_BINARY=libreoffice
# DOC 转换超时时间，单位秒
CONVERSION_TIMEOUT_SECONDS=60

# 文档摘要接口一次最多上传的文件数
SUMMARY_MAX_FILES=10
# 长文档摘要时保留的文档开头字符数
SUMMARY_INITIAL_CHARS=20000
# 非 PDF 文档用于扫描疑似目录的开头字符数
SUMMARY_TOC_SCAN_CHARS=30000
# 疑似目录内容最大保留字符数
SUMMARY_TOC_MAX_CHARS=8000
# 摘要正文切片大小，单位字符
SUMMARY_CHUNK_MAX_CHARS=12000
# 长文档摘要最多选取的正文切片数
SUMMARY_MAX_CHUNKS=4
# 多个摘要切片之间的模型调用间隔，单位秒
SUMMARY_CHUNK_DELAY_SECONDS=0.2
# PDF 长文档摘要时优先保留的前几页内容
SUMMARY_INITIAL_PDF_PAGES=5
# PDF 用于扫描疑似目录的前几页
SUMMARY_TOC_PDF_PAGES=10
# PDF 最多解析页数，超过后不继续读取
SUMMARY_MAX_PDF_PAGES=50

# 异步任务队列最大排队数量
ASYNC_QUEUE_MAX_SIZE=100
# 异步任务 worker 数量，拟稿事由和文档摘要异步任务共用
ASYNC_WORKER_COUNT=2
# 异步任务结果和失败记录保留时间，单位秒
ASYNC_JOB_TTL_SECONDS=3600
# 异步任务 SQLite 状态库和上传源文件目录
ASYNC_DATA_DIR=./data
